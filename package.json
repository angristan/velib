{
  "name": "velib",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "check": "bun run typecheck && bun run test && bun run build",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:workerd": "vitest run --project workerd",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --config wrangler.jsonc --env-file /dev/null",
    "cf-typegen:check": "wrangler types --config wrangler.jsonc --env-file /dev/null --check",
    "db:migrate:local": "wrangler d1 migrations apply velib --config wrangler.jsonc --local",
    "db:migrate:remote": "wrangler d1 migrations apply velib --config wrangler.jsonc --remote",
    "deploy": "bun run check && bun run db:migrate:remote && wrangler deploy --config wrangler.jsonc"
  },
  "dependencies": {
    "@fontsource-variable/nunito": "5.2.7",
    "@fontsource-variable/red-hat-display": "5.2.8",
    "@mantine/charts": "9.4.1",
    "@mantine/core": "9.4.1",
    "@mantine/hooks": "9.4.1",
    "@tabler/icons-react": "3.44.0",
    "@tanstack/react-virtual": "3.14.6",
    "effect": "4.0.0-beta.98",
    "maplibre-gl": "5.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.9.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.44.0",
    "@cloudflare/vitest-pool-workers": "0.18.4",
    "@effect/vitest": "4.0.0-beta.98",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
